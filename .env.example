# PostgreSQL database credentials
DB_USER=
DB_HOST=
DB_NAME=
DB_PASSWORD=
DB_PORT=

# Frontend URL
FRONTEND_URL=

# JWT secret key for authentication
JWT_SECRET=

# OAuth internal secret key for authentication
OAUTH_INTERNAL_SECRET=

# AWS credentials for S3 storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# S3 bucket name for media storage
S3_BUCKET=

# Media URL secret key for encryption
MEDIA_URL_SECRET=

# Geoapify — address autocomplete (https://www.geoapify.com/)
GEOAPIFY_API_KEY=

# Twilio — phone number verification and SMS notifications
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Stripe secret key for payment processing
STRIPE_SECRET_KEY=

# Crypto checkout — mock treasury wallets (dev only; replace with real merchant wallets in production)
WORKLANC_TREASURY_SOLANA=
WORKLANC_TREASURY_ETHEREUM=
WORKLANC_TREASURY_BNB=

# Optional custom RPC endpoints (defaults to public mainnet RPCs)
# CRYPTO_RPC_SOLANA=
# CRYPTO_RPC_ETHEREUM=
# CRYPTO_RPC_BNB=
# CRYPTO_USE_TESTNETS=false

# Payoneer — talent withdrawal payouts (sandbox by default)
PAYONEER_CLIENT_ID=
PAYONEER_CLIENT_SECRET=
PAYONEER_PROGRAM_ID=
# sandbox | production
PAYONEER_ENV=sandbox
# Optional overrides
# PAYONEER_API_BASE_URL=https://api.sandbox.payoneer.com
# PAYONEER_REDIRECT_URL=

# Solana token mints for CHRLE/BABYU pricing + on-chain verification
CHRLE_TOKEN_ADDRESS=
BABYU_TOKEN_ADDRESS=