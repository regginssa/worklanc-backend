DB_USER=
DB_HOST=
DB_NAME=
DB_PASSWORD=
DB_PORT=
JWT_SECRET=

# Must match OAUTH_INTERNAL_SECRET in frontend/.env.local
OAUTH_INTERNAL_SECRET=

# Twilio Verify (https://console.twilio.com/us1/develop/verify/services)
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option A — Account SID + Auth Token
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=

# Option B — API key (when TWILIO_ACCOUNT_SID is an SK... API key SID)
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=
TWILIO_PARENT_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
