DB_USER=
DB_HOST=
DB_NAME=
DB_PASSWORD=
DB_PORT=
JWT_SECRET=

# Must match OAUTH_INTERNAL_SECRET in frontend/.env.local
OAUTH_INTERNAL_SECRET=

# Twilio SMS (trial: use Messages API + verified recipient numbers)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Optional — Twilio Verify (paid; not required for trial Messages flow)
# TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
